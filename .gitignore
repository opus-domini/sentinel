# Allowlist gitignore for the Sentinel repo. Anything not explicitly
# allowed below is ignored, so new top-level files and directories do not
# get committed by accident.

# Ignore everything
*

# Top-level files
!/.gitignore
!/README.md
!/CONTRIBUTING.md
!/CHANGELOG.md
!/LICENSE
!/Makefile
!/.golangci.yml
!/.goreleaser.yaml
!/go.mod
!/go.sum
!/install.sh
!/uninstall.sh

# Source trees
!/cmd
!/cmd/**/*
!/internal
!/internal/**/*

# Frontend (client/ carries its own .gitignore)
!/client

# Docs, scripts and CI
!/docs
!/docs/**/*
!/scripts
!/scripts/**/*
!/.github
!/.github/**/*
