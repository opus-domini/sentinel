# Allowlist gitignore for the Sentinel repo. Anything not explicitly
# allowed below is ignored, so new top-level files and directories do not
# get committed by accident.

# Ignore everything
*

# Top-level files
!/.gitignore
!/README.md
!/CONTRIBUTING.md
!/CHANGELOG.md
!/LICENSE
!/Makefile
!/.golangci.yml
!/.goreleaser.yaml
!/go.mod
!/go.sum
!/install.sh

# Source trees
!/cmd
!/cmd/**/*
!/internal
!/internal/**/*

# Embedded web UI build output. The frontend build regenerates these files
# before Go builds in Makefile, CI and GoReleaser; only the placeholder stays
# tracked so go:embed compiles on a fresh clone.
/internal/ui/dist/*
!/internal/ui/dist/.gitkeep

# Frontend (frontend/ carries its own .gitignore)
!/frontend

# Docs, scripts and CI
!/docs
!/docs/**/*
!/scripts
!/scripts/**/*
!/.github
!/.github/**/*
