{
  "name": "sentinel-client",
  "private": true,
  "version": "0.5.36",
  "type": "module",
  "scripts": {
    "dev": "vite dev --host",
    "build": "vite build && cp public/index.html dist/index.html && cp public/manifest.webmanifest dist/manifest.webmanifest && cp public/sw.js dist/sw.js && cp public/favicon.ico public/favicon.png public/favicon.svg public/apple-touch-icon.png dist/ && mkdir -p dist/icons && cp public/icons/* dist/icons/",
    "preview": "vite preview",
    "test": "npm run test:unit",
    "test:unit": "node ./scripts/run-vitest.mjs run --passWithNoTests --exclude \"src/**/*.e2e.test.ts?(x)\"",
    "test:e2e": "node ./scripts/run-vitest.mjs run --passWithNoTests --config vitest.e2e.config.ts",
    "test:all": "npm run test:unit && npm run test:e2e",
    "typecheck": "tsc",
    "lint": "oxlint . && oxfmt --check .",
    "format": "oxfmt --write .",
    "check": "oxfmt --write . && oxlint --fix ."
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-router": "^1.170.5",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-unicode-graphemes": "^0.4.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cron-parser": "^5.5.0",
    "cronstrue": "^3.14.0",
    "lucide-react": "^1.16.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@tanstack/router-plugin": "^1.168.7",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.7",
    "web-vitals": "^5.2.0"
  }
}
