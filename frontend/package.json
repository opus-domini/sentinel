{
  "name": "sentinel-frontend",
  "private": true,
  "version": "0.8.1",
  "type": "module",
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": ">=24 <27",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "vite dev --host 127.0.0.1",
    "dev:host": "vite dev --host 0.0.0.0",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "test": "npm run test:unit",
    "test:unit": "node ./scripts/run-vitest.mjs run --passWithNoTests --exclude \"src/**/*.e2e.test.ts?(x)\"",
    "test:e2e": "node ./scripts/run-vitest.mjs run --passWithNoTests --config vitest.e2e.config.ts",
    "test:all": "npm run test:unit && npm run test:e2e",
    "typecheck": "tsc",
    "lint": "oxlint . --deny-warnings && oxfmt --check .",
    "format": "oxfmt --write .",
    "fix": "oxfmt --write . && oxlint --fix .",
    "check": "npm run typecheck && npm run lint && npm run test:unit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-router": "^1.170.9",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-unicode-graphemes": "^0.4.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cron-parser": "^5.5.0",
    "cronstrue": "^3.14.0",
    "lucide-react": "^1.17.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@tanstack/router-plugin": "^1.168.12",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
